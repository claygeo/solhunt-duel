# Provider (default: ollama). Options: ollama, openai, openrouter, anthropic
SOLHUNT_PROVIDER=ollama

# API keys (only needed for paid providers, not for Ollama)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# Etherscan API key (free tier: https://etherscan.io/apis)
ETHERSCAN_API_KEY=...

# Ethereum RPC endpoint (Alchemy free tier: https://www.alchemy.com/)
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Max agent iterations per contract (default: 30)
SOLHUNT_MAX_ITERATIONS=30

# Per-tool-call timeout in ms (default: 60000)
SOLHUNT_TOOL_TIMEOUT=60000

# Total scan timeout in ms (default: 1800000 = 30 min)
SOLHUNT_SCAN_TIMEOUT=1800000

# Provider (default: ollama). Options: ollama, openai, openrouter, anthropic
SOLHUNT_PROVIDER=ollama

# API keys (only needed for paid providers, not for Ollama)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...

# Etherscan API key (free tier: https://etherscan.io/apis)
# Note: Etherscan v2 multichain API — ONE key works for Ethereum, Arbitrum,
# Optimism, Base, Polygon, and ~50 other chains. The chainId is passed at
# call-time via --chain, no per-chain Etherscan account needed.
ETHERSCAN_API_KEY=...

# Per-chain RPC endpoints. Solhunt picks the right one based on --chain.
# At minimum, set ETH_RPC_URL for the default ethereum chain.
# Add others as you scan those chains.
#
# Alchemy free tier: https://www.alchemy.com/
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# OPT_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Supabase (optional — for persisting benchmark data)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...

# Max agent iterations per contract (default: 30)
SOLHUNT_MAX_ITERATIONS=30

# Per-tool-call timeout in ms (default: 60000)
SOLHUNT_TOOL_TIMEOUT=60000

# Total scan timeout in ms (default: 1800000 = 30 min)
SOLHUNT_SCAN_TIMEOUT=1800000

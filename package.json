{
  "name": "solhunt",
  "version": "0.1.0",
  "description": "Autonomous AI agent for smart contract vulnerability detection and exploitation",
  "type": "module",
  "bin": {
    "solhunt": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run test/e2e",
    "lint": "tsc --noEmit",
    "scan": "tsx src/index.ts scan",
    "benchmark": "tsx src/index.ts benchmark"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.2",
    "chalk": "^5.4.1",
    "commander": "^13.0.0",
    "dockerode": "^4.0.4",
    "dotenv": "^16.4.7",
    "js-sha3": "^0.9.3",
    "ora": "^8.2.0",
    "undici": "^7.25.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
